{
  "name": "@openclaw/hierarchical",
  "version": "0.1.0",
  "description": "Tree-hierarchy agent plugin for OpenClaw — inherited prompts (PLS) and node-type tool isolation (NTS)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --import tsx --test tests/unit/**/*.test.ts tests/integration/**/*.test.ts",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/**/*.test.ts",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "@openclaw/plugin-sdk": ">=0.0.0"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "latest",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=0.0.0"
    },
    "build": {
      "openclawVersion": "0.0.0-private",
      "pluginSdkVersion": "0.0.0-private"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "author": "OpenClaw Contributors",
  "homepage": "https://github.com/openclaw/hierarchical-plugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/hierarchical-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/hierarchical-plugin/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "hierarchical",
    "agent",
    "PLS",
    "NTS"
  ]
}